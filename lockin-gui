    # ================================================================
    # Lock In
    # ================================================================

    def on_lockin(self, button):
        if not self.allowed_sites:
            self.show_error("Add at least one allowed site first.")
            return

        self.lockin_btn.set_sensitive(False)
        self.lockin_btn.set_label("STARTING...")

        # Build command
        sites_str = " ".join(self.allowed_sites)
        cmd = f"lockin start {self.selected_minutes} {sites_str}"

        # Run with pkexec for graphical sudo
        try:
            result = subprocess.run(
                ["pkexec", "bash", "-c", cmd],
                capture_output=True, text=True, timeout=30
            )
            if result.returncode != 0:
                error_msg = result.stderr.strip() or result.stdout.strip() or "Failed to start session"
                self.show_error(error_msg)
                self.lockin_btn.set_sensitive(True)
                self.lockin_btn.set_label("LOCK IN")
                return
        except subprocess.TimeoutExpired:
            self.show_error("Timed out starting session.")
            self.lockin_btn.set_sensitive(True)
            self.lockin_btn.set_label("LOCK IN")
            return
        except FileNotFoundError:
            self.show_error("'lockin' not found. Run install.sh first.")
            self.lockin_btn.set_sensitive(True)
            self.lockin_btn.set_label("LOCK IN")
            return

        # Switch to active view
        self.session_active = True
        self.switch_to_active()

    def switch_to_active(self):
        # Read session details
        end_time, duration = self.read_session()

        if end_time is None:
            # Fallback: use selected values
            end_time = time.time() + self.selected_minutes * 60
            duration = self.selected_minutes

        self.session_end_time = end_time
        self.session_duration = duration

        # Update active view
        ends_str = time.strftime("%H:%M", time.localtime(end_time))
        self.ends_at_label.set_text(ends_str)
        self.duration_label.set_text(f"{duration}m")

        # Render allowed sites
        for child in self.active_sites_box.get_children():
            self.active_sites_box.remove(child)

        for domain in self.allowed_sites:
            item = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            item.get_style_context().add_class("allowed-item")
            item.set_margin_start(0)
            item.set_margin_end(0)

            dot = Gtk.Label(label="\u25cf")
            dot.get_style_context().add_class("allowed-dot")
            item.pack_start(dot, False, False, 0)

            name = Gtk.Label(label=domain)
            name.get_style_context().add_class("allowed-domain")
            name.set_halign(Gtk.Align.START)
            item.pack_start(name, True, True, 0)

            self.active_sites_box.pack_start(item, False, False, 0)

        self.active_sites_box.show_all()

        # Start timer
        self.update_timer()
        if self.timer_id:
            GLib.source_remove(self.timer_id)
        self.timer_id = GLib.timeout_add_seconds(1, self.update_timer)

        # Check guard status
        self.update_guard_status()
        GLib.timeout_add_seconds(10, self.update_guard_status)

        self.stack.set_visible_child_name("active")

    def update_timer(self):
        now = time.time()
        remaining = max(0, self.session_end_time - now)
        total = self.session_duration * 60

        if remaining <= 0:
            self.timer_label.set_text("00:00")
            self.progress_bar.set_fraction(1.0)
            self.session_active = False
            # Switch back to setup after a moment
            GLib.timeout_add(2000, self.switch_to_setup)
            return False  # Stop timer

        mins = int(remaining // 60)
        secs = int(remaining % 60)
        self.timer_label.set_text(f"{mins:02d}:{secs:02d}")

        elapsed = total - remaining
        fraction = elapsed / total if total > 0 else 0
        self.progress_bar.set_fraction(fraction)

        return True  # Continue timer

    def update_guard_status(self):
        if not self.session_active:
            return False
        try:
            result = subprocess.run(
                ["systemctl", "is-active", "lockin-guard.service"],
                capture_output=True, text=True, timeout=5
            )
            if result.stdout.strip() == "active":
                self.guard_label.set_markup('<span foreground="#22c55e">ACTIVE</span>')
            else:
                self.guard_label.set_markup('<span foreground="#ef4444">DOWN</span>')
        except Exception:
            self.guard_label.set_markup('<span foreground="#71717a">UNKNOWN</span>')
        return self.session_active

    def switch_to_setup(self):
        self.session_active = False
        self.lockin_btn.set_sensitive(True)
        self.lockin_btn.set_label("LOCK IN")
        if self.timer_id:
            GLib.source_remove(self.timer_id)
            self.timer_id = None
        self.stack.set_visible_child_name("setup")
        return False

    # ================================================================
    # Session helpers
    # ================================================================

    def read_session(self):
        """Read /etc/lockin/session to get end time and duration."""
        try:
            with open("/etc/lockin/session") as f:
                content = f.read()
            end_time = None
            duration = None
            for line in content.splitlines():
                if line.startswith("END_TIME="):
                    end_time = int(line.split("=", 1)[1])
                elif line.startswith("DURATION_MINUTES="):
                    duration = int(line.split("=", 1)[1])
            return end_time, duration
        except (FileNotFoundError, PermissionError, ValueError):
            return None, None

    def check_existing_session(self):
        """On startup, check if a session is already running."""
        end_time, duration = self.read_session()
        if end_time and time.time() < end_time:
            self.session_active = True
            self.session_end_time = end_time
            self.session_duration = duration or 25

            # Try to read allowed domains from session
            try:
                with open("/etc/lockin/session") as f:
                    for line in f:
                        if line.startswith("ALLOWED_DOMAINS="):
                            domains = line.strip().split("=", 1)[1]
                            self.allowed_sites = [d.strip() for d in domains.split(",") if d.strip()]
            except Exception:
                pass

            GLib.idle_add(self.switch_to_active)

    # ================================================================
    # Window close blocking
    # ================================================================

    def on_close(self, widget, event):
        if self.session_active:
            # Prevent closing during active session
            dialog = Gtk.MessageDialog(
                transient_for=self,
                modal=True,
                message_type=Gtk.MessageType.WARNING,
                buttons=Gtk.ButtonsType.OK,
                text="You're locked in."
            )
            dialog.format_secondary_text(
                "This window cannot be closed during an active session. "
                "The session will end when the timer reaches zero."
            )
            dialog.run()
            dialog.destroy()
            return True  # Prevent close
        return False  # Allow close

    # ================================================================
    # Error display
    # ================================================================

    def show_error(self, message):
        self.error_label.set_text(message)
        self.error_label.show()

    def hide_error(self):
        self.error_label.hide()


# ============================================================================
# Main
# ============================================================================

def main():
    app = LockInApp()
    app.connect("destroy", Gtk.main_quit)
    app.show_all()
    app.error_label.hide()

    # If session is active on launch, ensure we're on active view
    Gtk.main()


if __name__ == "__main__":
    main()
