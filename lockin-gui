    # ================================================================
    # Duration toggle logic
    # ================================================================

    def on_duration_toggled(self, button, minutes):
        if button.get_active():
            self.selected_minutes = minutes
            # Untoggle other buttons
            for mins, btn in self.dur_buttons.items():
                if mins != minutes and btn.get_active():
                    btn.handler_block_by_func(self.on_duration_toggled)
                    btn.set_active(False)
                    btn.handler_unblock_by_func(self.on_duration_toggled)
        else:
            # Don't allow deselecting the current one
            if self.selected_minutes == minutes:
                button.handler_block_by_func(self.on_duration_toggled)
                button.set_active(True)
                button.handler_unblock_by_func(self.on_duration_toggled)

    # ================================================================
    # Sites management
    # ================================================================

    def on_add_site(self, *args):
        raw = self.site_entry.get_text().strip().lower()
        raw = raw.replace("https://", "").replace("http://", "")
        raw = raw.removeprefix("www.")
        raw = raw.split("/")[0]

        if not raw or raw in self.allowed_sites:
            self.site_entry.set_text("")
            return

        self.allowed_sites.append(raw)
        self.save_sites()
        self.render_sites()
        self.site_entry.set_text("")
        self.site_entry.grab_focus()
        self.hide_error()

    def remove_site(self, domain):
        self.allowed_sites = [s for s in self.allowed_sites if s != domain]
        self.save_sites()
        self.render_sites()

    def render_sites(self):
        # Clear existing
        for child in self.sites_flow.get_children():
            self.sites_flow.remove(child)

        for domain in self.allowed_sites:
            tag_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
            tag_box.get_style_context().add_class("site-tag")

            label = Gtk.Label(label=domain)
            label.set_margin_start(2)
            tag_box.pack_start(label, False, False, 0)

            remove_btn = Gtk.Button(label="\u00d7")
            remove_btn.get_style_context().add_class("site-tag-remove")
            remove_btn.connect("clicked", lambda b, d=domain: self.remove_site(d))
            tag_box.pack_start(remove_btn, False, False, 0)

            self.sites_flow.add(tag_box)

        self.sites_flow.show_all()

    def save_sites(self):
        path = os.path.join(self.config_path, "sites.json")
        with open(path, "w") as f:
            json.dump(self.allowed_sites, f)

    def load_saved_sites(self):
        path = os.path.join(self.config_path, "sites.json")
        try:
            with open(path) as f:
                self.allowed_sites = json.load(f)
        except (FileNotFoundError, json.JSONDecodeError):
            self.allowed_sites = []

