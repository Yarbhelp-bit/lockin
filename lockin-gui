class LockInApp(Gtk.Window):
    def __init__(self):
        super().__init__(title="Lock In")
        self.set_default_size(420, 620)
        self.set_resizable(False)
        self.set_position(Gtk.WindowPosition.CENTER)

        # State
        self.selected_minutes = 25
        self.allowed_sites = []
        self.session_active = False
        self.timer_id = None

        # Load saved sites
        self.config_path = os.path.expanduser("~/.config/lockin")
        os.makedirs(self.config_path, exist_ok=True)
        self.load_saved_sites()

        # Apply CSS
        style_provider = Gtk.CssProvider()
        style_provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            style_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        # Main stack for view switching
        self.stack = Gtk.Stack()
        self.stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
        self.stack.set_transition_duration(200)

        # Build views
        self.stack.add_named(self.build_setup_view(), "setup")
        self.stack.add_named(self.build_active_view(), "active")

        self.add(self.stack)

        # Check if session is already running
        self.check_existing_session()

        # Block closing during session
        self.connect("delete-event", self.on_close)

